{
  "manifest_version": 1,
  "name": "QQ 收藏表情同步",
  "version": "1.1.0",
  "description": "通过 NapCat 扩展接口读取当前 QQ 账号的收藏表情，并安全写入 MaiBot 待注册表情目录。",
  "author": {
    "name": "RiyaBot"
  },
  "license": "GPL-v3.0-or-later",
  "host_application": {
    "min_version": "0.13.0"
  },
  "homepage_url": "https://github.com/hsd221/riyabot",
  "repository_url": "https://github.com/hsd221/riyabot",
  "keywords": [
    "qq",
    "onebot",
    "napcat",
    "emoji"
  ],
  "categories": [
    "Adapter",
    "Utility"
  ],
  "default_locale": "zh-CN",
  "plugin_info": {
    "is_built_in": false,
    "plugin_type": "utility",
    "components": [
      {
        "type": "command",
        "name": "qq_emoji_sync",
        "description": "将当前 QQ 账号的收藏表情同步到待注册目录"
      }
    ]
  }
}
