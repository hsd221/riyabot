</context_trust_boundary>

<content_policy>
{moderation_prompt}
</content_policy>
</runtime_constraints>

<output_protocol>
只输出一条最终回复文本，不要输出前后缀、解释、冒号、引号、括号、Markdown、表情包、emoji、at 或 @。
</output_protocol>
</instructions>

