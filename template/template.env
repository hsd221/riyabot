# 璃夜主程序配置
HOST=127.0.0.1
PORT=8000
# 旧版消息服务器跨主机/容器连接时，核心与适配器必须使用同一随机令牌
MAIBOT_LEGACY_SERVER_TOKEN=
# 仅用于迁移受信旧环境；开启后允许旧版消息服务器远程匿名监听
MAIBOT_ALLOW_UNAUTHENTICATED_LEGACY_SERVER=0

# WebUI 服务器配置
WEBUI_HOST=127.0.0.1
WEBUI_PORT=8001

# 可选：使用自建 HTTPS 遥测端点（bot_config.toml 中 telemetry.enable=true 时生效）
# MAIBOT_TELEMETRY_SERVER_URL=https://telemetry.example.com
# 仅兼容旧端点时才显式启用明文 HTTP；不推荐
# MAIBOT_ALLOW_INSECURE_TELEMETRY=0

# 可选：仅兼容受信旧环境时允许新版 API Server 在远程监听且不配置 API Key；强烈不推荐
# MAIBOT_ALLOW_UNAUTHENTICATED_API_SERVER=0

# 仅测试使用：显式启用消息注入端点；非回环 HOST 必须同时设置独立强随机 Token
# MAIBOT_ENABLE_INJECT_ENDPOINT=0
# MAIBOT_INJECT_TOKEN=

# 可选：仅兼容公网明文模型 API 时显式放行 HTTP；本机与 RFC1918/ULA 私网 HTTP 默认兼容
# MAIBOT_ALLOW_INSECURE_MODEL_URLS=0
# 可选：确需可信 HTTP(S) 出站代理访问模型供应商时显式启用
# MAIBOT_ALLOW_MODEL_PROXY=0

# 可选：插件仓库位于内网/本机时显式放行私有地址
# MAIBOT_ALLOW_PRIVATE_GIT_URLS=0
# 可选：兼容仅支持 HTTP 或 git:// 的旧仓库；不推荐
# MAIBOT_ALLOW_INSECURE_GIT_URLS=0
# 可选：确需可信 HTTP(S) 出站代理时显式启用；代理将参与目标解析，请谨慎配置
# MAIBOT_ALLOW_GIT_PROXY=0

# OneBot 消息卡片中的媒体 URL 默认只能访问公网 80/443，避免 SSRF
# 仅在受信内网媒体服务确有需要时启用以下兼容开关
# MAIBOT_ALLOW_PRIVATE_MEDIA_URLS=0
# MAIBOT_ALLOW_NONSTANDARD_MEDIA_PORTS=0

# 反向代理导致 Origin 与 Host 不一致时，可列出额外允许的 WebSocket 来源（逗号分隔）
# MAIBOT_ALLOWED_WS_ORIGINS=https://bot.example.com

# 可选：允许 WebUI 读写项目目录外的适配器 TOML；仅对受信路径显式启用
# MAIBOT_ALLOW_EXTERNAL_ADAPTER_CONFIG=0
